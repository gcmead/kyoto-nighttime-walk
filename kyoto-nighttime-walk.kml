<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Kyoto Night Walk · 20 spots, 3 okonomiyaki</name>
  <description><![CDATA[Walk-in friendly · no set menus · Kiyamachi + Pontocho/Kawaramachi + Gion]]></description>

  <Style id="locked"><IconStyle><scale>1.3</scale><Icon><href>https://maps.google.com/mapfiles/kml/paddle/ylw-stars.png</href></Icon></IconStyle></Style>
  <Style id="major"><IconStyle><scale>1.1</scale><Icon><href>https://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon></IconStyle></Style>
  <Style id="bonus"><IconStyle><scale>0.9</scale><Icon><href>https://maps.google.com/mapfiles/kml/paddle/blu-blank.png</href></Icon></IconStyle></Style>
  <Style id="station"><IconStyle><scale>0.9</scale><Icon><href>https://maps.google.com/mapfiles/kml/shapes/rail.png</href></Icon></IconStyle></Style>

  <Folder>
    <name>LOCKED — confirmed bookings / hard anchors</name>
    <Placemark>
      <name>Ritz-Carlton Kyoto — start &amp; end</name>
      <description><![CDATA[<b>Start ~17:00 · loop back by midnight</b><br><br><b>WHAT IT IS:</b> Home base. The whole night-walk is a loop from here, ~3-5 km on foot through 3 distinct evening neighborhoods.<br><br><b>WHY FOR YOU:</b> Walking distance to all 19 picks. Kiyamachi cluster 8-12 min south; Pontocho/Kawaramachi 10-15 min southwest; Gion 12-18 min southeast across the Kamogawa.<br><br>Address: Kamogawa Nijo-Ohashi Hotori, Nakagyo-ku]]></description>
      <styleUrl>#locked</styleUrl>
      <Point><coordinates>135.77078,35.01428,0</coordinates></Point>
    </Placemark>
  </Folder>

  <Folder>
    <name>MAJOR — the planned spine</name>
    <Placemark>
      <name>立ち呑み もみじ (Tachinomi Momiji)</name>
      <description><![CDATA[<b>Daily 12:00-22:00 LO 21:30 · cash only · standing</b><br><br><b>WHAT IT IS:</b> Standing counter izakaya at Kiyamachi-Shijo gateway. Oden, sashimi small plates, lemon sour, sake.<br><br><b>WHY FOR YOU:</b> Tabelog explicit: 'Reservations unavailable.' Pure walk-in. Japanese-majority salaryman after-work crowd.<br><br>Address: 京都市中京区鍋屋町225 萩原ビル 1F<br><br><b>↪ ~13 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7692,35.0041,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>すいば 四条河原町 (Suiba Shijo Kawaramachi)</name>
      <description><![CDATA[<b>Mon-Fri 16:00-24:00 · Sat/Sun 15:00-24:00 · LO ~23:30 · closed Mon + 1st Tue</b><br><br><b>WHAT IT IS:</b> Standing bar, cheap-eats. Chuhai + lemon sour, takowasa, agedashi tofu, kushikatsu.<br><br><b>WHY FOR YOU:</b> Walk-in friendly. Mostly Japanese locals, women-friendly. The south Kawaramachi Suiba branch.<br><br>Address: 京都市中京区中之町569-2<br><br><b>↪ ~14 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76876,35.00385,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>立ち呑み処 origami (Tachinomi Origami)</name>
      <description><![CDATA[<b>Sun-Thu 17:00-01:00 · Fri/Sat 17:00-03:00 · open year-round</b><br><br><b>WHAT IT IS:</b> 14-seat standing counter. 50+ jizake, 100+ shochu/chuhai/highball. Fried small plates, sashimi.<br><br><b>WHY FOR YOU:</b> Tabelog 4.48 (very high). The DEEP sake/shochu list pick. Japanese-majority.<br><br>Address: 京都市中京区紙屋町363 オーシャンビル 1F<br><br><b>↪ ~10 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7696,35.0071,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>SAKE壱 (Sake Ichi)</name>
      <description><![CDATA[<b>Evening · verify on arrival</b><br><br><b>WHAT IT IS:</b> Walk-in standing counter, 200+ sake varieties. Tabelog 3.69. Simple pairings.<br><br><b>WHY FOR YOU:</b> Pure sake-flight pick. Japanese-majority, near Kawaramachi station.<br><br>Address: 京都市中京区材木町<br><br><b>↪ ~12 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7695,35.0042,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>たかせ会館 (Takase Kaikan) — Taisho-era kaikan</name>
      <description><![CDATA[<b>Evening · 'sit if empty, stand if crowded'</b><br><br><b>WHAT IT IS:</b> 1920s kaikan housing ~10 micro-shops in one converted building. Homemade osozai 5-piece platter, draft beer, sake.<br><br><b>WHY FOR YOU:</b> Japanese-only territory, nearly zero English. The deepest-locals Kiyamachi find.<br><br>Address: Kiyamachi south of Ritz<br><br><b>↪ ~5-7 min south of Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7695,35.0045,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>木屋町ゴールデン酒場 (Kiyamachi Golden Sakaba)</name>
      <description><![CDATA[<b>Wed 18:00-03:00 · 1F standing · 2F seated · walk-in OK</b><br><br><b>WHAT IT IS:</b> Showa-retro standing bar on Kiyamachi. Highball + chuhai + oden + kushiage ¥300-900. Late-night anchor — open till 03:00.<br><br><b>WHY FOR YOU:</b> Late-night Kiyamachi option. Japanese-majority drinkers, Showa atmosphere. Takes reservations but walk-ins fine — à la carte ordering.<br><br>Address: 京都市中京区木屋町通六角東側材木町184 都会館ビル 1F<br><br><b>↪ ~12 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76925,35.00854,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>京極スタンド (Kyogoku Stand) — 1927 taishu-shokudo</name>
      <description><![CDATA[<b>Wed 12:00-21:00 LO 20:45 · CLOSED Tuesdays · arrive by 19:45</b><br><br><b>WHAT IT IS:</b> 1927-founded retro working-class dining hall. Large bottle beer, fried oysters, hayashi rice. Multi-generational Japanese crowd.<br><br><b>WHY FOR YOU:</b> Timeout JP: 'No reservations, no waitlist.' Pure walk-in. Pre-war Kyoto preserved. ⚠ LO 20:45 — go early.<br><br>Address: 京都市中京区新京極通四条上ル中之町546<br><br><b>↪ ~14 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76781,35.005,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>すいば bal 河原町BAL北店 (Suiba Bal Kita)</name>
      <description><![CDATA[<b>12:00-15:00 + 17:00-03:00 · closed Tuesdays</b><br><br><b>WHAT IT IS:</b> Standing bar with later-night extension. Chuhai, kushi, oden.<br><br><b>WHY FOR YOU:</b> Open till 03:00 = post-everything pick. Mixed Japanese/young locals.<br><br>Address: 京都市中京区河原町通三条下ル北車屋町261-1 1F<br><br><b>↪ ~10 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76828,35.00833,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>立ち呑み ココロノコリ (Kokoronokori)</name>
      <description><![CDATA[<b>~17:00-24:00 · walk-in (¥100/hr seat charge if sitting)</b><br><br><b>WHAT IT IS:</b> Natural wine + small plates standing bar near Pontocho south end. Ahi tuna tartare, design-food-industry crowd.<br><br><b>WHY FOR YOU:</b> The wine pick (not sake/chuhai). Japanese-majority young professional. Walk-in standing.<br><br>Address: 京都市中京区下樵木町197<br><br><b>↪ ~13 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7702,35.004,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>レボリューションブックス (Revolution Books)</name>
      <description><![CDATA[<b>~12:00 to late</b><br><br><b>WHAT IT IS:</b> Walk-in standing bar + cookbook shop hybrid, 2F unit. Sashimi, karaage, whiskey.<br><br><b>WHY FOR YOU:</b> The weirdest pick — bar inside a bookshop. Timeout JP. Unique format, walk-in.<br><br>Address: Kawaramachi area, 2F<br><br><b>↪ ~12 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76945,35.0042,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🥞 鉄板 みつ喜 (Teppan Mitsuki) — POSCHO OKONOMIYAKI</name>
      <description><![CDATA[<b>Tue-Sun 18:00-01:00 LO 24:00 · CLOSED Mondays · Wed open · walk-in friendly</b><br><br><b>WHAT IT IS:</b> Pontocho okonomiyaki + teppan. Water-free signature style (denser batter, no water added). Treated as a drinking-spot first, food second. ¥3,000-3,999.<br><br><b>WHY FOR YOU:</b> Featured in Tabelog Magazine Japanese article as locals-frequented teppan that stayed off the tourist circuit. À la carte, no set-menu trap. Open till 01:00.<br><br>Address: 京都市中京区木屋町四条上ル下樵木町192<br><br><b>↪ ~15 min from Ritz, Pontocho alley near Shijo</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.77068,35.00339,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>たつみ (Tatsumi) — Kyoto Three Great Sakaba</name>
      <description><![CDATA[<b>Wed 12:00-22:00 LO 20:50 · CLOSED Thursday</b><br><br><b>WHAT IT IS:</b> Voted 'Kyoto Three Great Sakaba' by Japanese locals magazine potel.jp. Hi-Riki lemon chuhai + highball + sake. Standing or back tatami.<br><br><b>WHY FOR YOU:</b> Japanese-regulars, daytime + evening drinkers. ⚠ LO 20:50 — go by 20:00.<br><br>Address: 京都市中京区裏寺町通四条上ル中之町572<br><br><b>↪ ~14 min from Ritz · 2 min from Hankyu Kawaramachi</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76859,35.00404,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>すいば 六角富小路 (Suiba Rokkaku-Tomikoji)</name>
      <description><![CDATA[<b>Wed 17:00-23:30 LO 23:30 · standing · walk-in</b><br><br><b>WHAT IT IS:</b> Standing-bar consensus pick per Japanese locals. Sawa (lemon sour) + Kyoto sake. ~¥1,500.<br><br><b>WHY FOR YOU:</b> Different branch from K2 — this is the Rokkaku-Tomikoji branch, slightly west of Teramachi at Rokkaku. Japanese-dominant.<br><br>Address: 京都市中京区六角通柳馬場東入ル77 河村ビル1階<br><br><b>↪ ~10 min from Ritz, west of Teramachi</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76651,35.00903,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>山口大亭 東店 (Yamaguchi Daitei Higashi)</name>
      <description><![CDATA[<b>Mon-Thu + Sat 17:00-22:00 LO 21:30 · CLOSED Sundays · Wed open</b><br><br><b>WHAT IT IS:</b> 50+ year old neighborhood izakaya. 6-seat counter + 2F tatami. Oden, beef-tendon stew, large-bottle beer.<br><br><b>WHY FOR YOU:</b> Japanese-only crowd, 50s/60s regulars. Pure walk-in. The Gion neighborhood-izakaya canonical.<br><br>Address: 京都市東山区祇園町北側286<br><br><b>↪ ~14 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7762,35.00345,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GION TACHINOMI 山根子 (Yamaneko)</name>
      <description><![CDATA[<b>Daily 11:00-24:00 · walk-in · cash-on per drink</b><br><br><b>WHAT IT IS:</b> Tachinomi inside renovated 150-year-old machiya. 8 Kyoto craft beers on tap, sake refrigerator self-serve. Maizuru dried fish, hotaru-ika.<br><br><b>WHY FOR YOU:</b> Cash-on-per-drink system = pure walk-in. Japanese-majority + craft-beer expats. The Gion machiya pick.<br><br>Address: 京都市東山区祇園町北側321-1<br><br><b>↪ ~13 min from Ritz across Sanjo-Ohashi</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.77735,35.00375,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>我逢人かっぱ (Gahojin Kappa) — all ¥390</name>
      <description><![CDATA[<b>Tue-Sat 18:00-03:00 · Sun 17:00-00:30 · CLOSED Mondays</b><br><br><b>WHAT IT IS:</b> 6-seat counter + 2F tatami. EVERY item ¥390+tax (yakitori, sashimi, tofu, sides). Highball + sake.<br><br><b>WHY FOR YOU:</b> Flat-price ¥390 gimmick = no tab math, just stack orders. Late-night (03:00 close).<br><br>Address: 京都市東山区八坂新地末吉町77<br><br><b>↪ ~15 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7755,35.0021,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>あぶり屋 ぶんぞう (Aburiya Bunzo) — gyutan</name>
      <description><![CDATA[<b>18:00-03:00 · irregular closing · walk-in</b><br><br><b>WHAT IT IS:</b> Charcoal-grilled skewer counter, gyutan (beef tongue) + beef cartilage specialty. Sasami, lemon sour, sake.<br><br><b>WHY FOR YOU:</b> Gyutan + cartilage = Tohoku influence in Gion. Japanese-majority. Late hours.<br><br>Address: 京都市東山区富永町123<br><br><b>↪ ~15 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.776,35.00295,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>山口西店 (Yamaguchi Nishi) — sister of Daitei</name>
      <description><![CDATA[<b>17:30-01:00 · CLOSED Sundays · walk-in</b><br><br><b>WHAT IT IS:</b> Sister of G1 Yamaguchi Daitei Higashi. 8-seat counter + tables + 2F tatami. Beef curry stew, seasoned rice, large beer.<br><br><b>WHY FOR YOU:</b> Hanamikoji edge. If G1 is closed/full, same family's other shop. Open till 01:00.<br><br>Address: 京都市東山区花見小路末吉町西入ル374-2<br><br><b>↪ ~15 min from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.77565,35.0026,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🥞 祇園たんと (Gion Tanto) — SHIRAKAWA OKONOMIYAKI</name>
      <description><![CDATA[<b>Wed dinner 16:30-21:30 LO 21:30 · CLOSED Thursdays · walk-in (no reservations)</b><br><br><b>WHAT IT IS:</b> Kyoto-style okonomiyaki + iron-plate dishes + chuhai. Small neighborhood teppan counter on Shirakawa Canal near Tatsumi Bridge, Gion edge.<br><br><b>WHY FOR YOU:</b> Fluffy-yet-substantial Kyoto okonomiyaki, fresh lemon sours, no-frills counter format. NOT reservation-required. Locals + repeat visitors, à la carte.<br><br>Address: 京都市東山区清本町372 (Higashiyama-ku, Kiyomotocho 372)<br><br><b>↪ ~12 min from Ritz south along Kamogawa into Gion</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7745,35.00455,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🥞 お好み焼 きらく 三条本店 (Okonomiyaki Kiraku Sanjo) — third okonomiyaki</name>
      <description><![CDATA[<b>Wed 11:30-13:40 LO + 17:00-22:00 LO · CLOSED Mondays · walk-in</b><br><br><b>WHAT IT IS:</b> Long-time local-favorite Kyoto okonomiyaki + teppan, casual neighborhood izakaya energy. Regulars, no spectacle. Fresh chuhai/lemon sours.<br><br><b>WHY FOR YOU:</b> Locals-heavy alt to Gion Tanto. Hidden-alley feel. Three different okonomiyaki cooks across the night-walk: Mitsuki (S5, Pontocho), Tanto (G6, Shirakawa), Kiraku (G7, Sanjo-east).<br><br>Address: 京都市東山区三条通白川橋東4丁目中之町208<br><br><b>↪ ~15 min from Ritz east via Sanjo · 5 min from Higashiyama station</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.779,35.00833,0</coordinates></Point>
    </Placemark>
  </Folder>

  <Folder>
    <name>STATIONS — transit hubs</name>
    <Placemark>
      <name>Kawaramachi (Hankyu line)</name>
      <description><![CDATA[<b>Closest to Kiyamachi + Shinkyogoku cluster</b><br><br><b>WHAT IT IS:</b> Hankyu Kyoto line. Heart of Kawaramachi-Shijo commercial node.]]></description>
      <styleUrl>#station</styleUrl>
      <Point><coordinates>135.76879,35.00343,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Gion-Shijo (Keihan line)</name>
      <description><![CDATA[<b>Gion area transit</b><br><br><b>WHAT IT IS:</b> Keihan line. All Gion picks within 5-10 min walk.]]></description>
      <styleUrl>#station</styleUrl>
      <Point><coordinates>135.77272,35.00343,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Sanjo (Keihan + Tozai)</name>
      <description><![CDATA[<b>Cross-river hub</b><br><br><b>WHAT IT IS:</b> Sanjo-Ohashi bridge — main Kamogawa crossing for the Kiyamachi-to-Gion transition.]]></description>
      <styleUrl>#station</styleUrl>
      <Point><coordinates>135.77151,35.0091,0</coordinates></Point>
    </Placemark>
  </Folder>

</Document>
