<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Kyoto Night Walk · Golden Path</name>
  <description><![CDATA[5 stops north→south then loop home · 🥞 okonomiyaki · 🍋 chuhai · 🍶 sake · 🍺 craft beer]]></description>

  <Style id="locked"><IconStyle><scale>1.3</scale><Icon><href>https://maps.google.com/mapfiles/kml/paddle/ylw-stars.png</href></Icon></IconStyle></Style>
  <Style id="major"><IconStyle><scale>1.1</scale><Icon><href>https://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon></IconStyle></Style>
  <Style id="bonus"><IconStyle><scale>0.9</scale><Icon><href>https://maps.google.com/mapfiles/kml/paddle/blu-blank.png</href></Icon></IconStyle></Style>
  <Style id="station"><IconStyle><scale>0.9</scale><Icon><href>https://maps.google.com/mapfiles/kml/shapes/rail.png</href></Icon></IconStyle></Style>

  <Folder>
    <name>LOCKED — confirmed bookings / hard anchors</name>
    <Placemark>
      <name>Ritz-Carlton Kyoto — start &amp; end</name>
      <description><![CDATA[<b>Start ~17:30 · loop south down Kiyamachi → cross to Gion → home via Kamogawa by ~midnight</b><br><br><b>WHAT IT IS:</b> Home base. Gold dashed line on map = the recommended A-path. Pins along the path = walking alternates if a primary is full or closed.<br><br>Address: Kamogawa Nijo-Ohashi Hotori, Nakagyo-ku]]></description>
      <styleUrl>#locked</styleUrl>
      <Point><coordinates>135.77078,35.01428,0</coordinates></Point>
    </Placemark>
  </Folder>

  <Folder>
    <name>MAJOR — the planned spine</name>
    <Placemark>
      <name>🍋 Suiba Bal Kita (すいば bal 河原町BAL北店) · STOP 1</name>
      <description><![CDATA[<b>STOP 1 · ~17:30 · 12:00-15:00 + 17:00-03:00 · closed Tue</b><br><br><b>WHAT IT IS:</b> Standing chuhai bar with late hours. Chuhai, lemon sour, kushi, oden.<br><br><b>WHY FOR YOU:</b> First stop walking south from Ritz down Kiyamachi/Kawaramachi. Opens 17:00, casual entry. Same area as 1B Origami (5 min walk south of here).<br><br>Address: 京都市中京区河原町通三条下ル北車屋町261-1 1F<br><br><b>↪ ~10 min south from Ritz</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76828,35.00833,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍶 Tachinomi Origami (立ち呑み処 origami) · STOP 1 alt</name>
      <description><![CDATA[<b>STOP 1 ALT · Sun-Thu 17:00-01:00 · open year-round</b><br><br><b>WHAT IT IS:</b> 14-seat standing counter, 50+ jizake / 100+ shochu/chuhai/highball. Fried small plates, sashimi.<br><br><b>WHY FOR YOU:</b> Same area as 1A (~5 min south). Tabelog 4.48. Pick if you want a deep sake program over chuhai-bar standing. Could do both — 1A first, then walk south to 1B before continuing to Stop 2.<br><br>Address: 京都市中京区紙屋町363 オーシャンビル 1F<br><br><b>↪ ~12 min from Ritz · 5 min south of 1A</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7696,35.0071,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍋 Tatsumi (たつみ) — Kyoto Three Great Sakaba · STOP 2</name>
      <description><![CDATA[<b>STOP 2 · ~19:00 · ⚠ LO 20:50 · closed Thursday</b><br><br><b>WHAT IT IS:</b> Voted 'Kyoto Three Great Sakaba' by Japanese locals magazine. Hi-Riki Lemon chuhai + highball + sake. Standing or back tatami.<br><br><b>WHY FOR YOU:</b> Mid-walk anchor at Kawaramachi-Shijo. ⚠ LO 20:50 — leave Stop 1 by 18:30 to be safe.<br><br>Address: 京都市中京区裏寺町通四条上ル中之町572<br><br><b>↪ ~14 min from Ritz · 2 min from Hankyu Kawaramachi station</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76859,35.00404,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍋 Suiba Shijo Kawaramachi · STOP 2 alt</name>
      <description><![CDATA[<b>STOP 2 ALT · Mon-Fri 16:00-24:00 · LO 23:30 · closed Mon + 1st Tue</b><br><br><b>WHAT IT IS:</b> Casual standing chuhai bar. Lemon sour, takowasa, agedashi tofu, kushikatsu.<br><br><b>WHY FOR YOU:</b> Same block as 2A (~30m apart). Open till 24:00 = forgiving timing if you miss Tatsumi's 20:50.<br><br>Address: 京都市中京区中之町569-2<br><br><b>↪ ~14 min from Ritz, adjacent to 2A</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.76876,35.00385,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🥞🍋 Teppan Mitsuki (鉄板 みつ喜) — DINNER · STOP 3</name>
      <description><![CDATA[<b>STOP 3 · ~20:30 dinner · Tue-Sun 18:00-01:00 LO 24:00 · CLOSED Mon</b><br><br><b>WHAT IT IS:</b> Pontocho okonomiyaki + teppan. Water-free signature style. Treated as drinking-spot first, food second. Fresh chuhai/lemon sours. À la carte.<br><br><b>WHY FOR YOU:</b> DINNER anchor. Pontocho alley, walk-in friendly, open till 01:00 — generous window. ⭐ Top-tier okonomiyaki.<br><br>Address: 京都市中京区木屋町四条上ル下樵木町192<br><br><b>↪ ~15 min from Ritz, Pontocho alley near Shijo · ~5 min from Stop 2</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.77068,35.00339,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🥞🍋 Gion Tanto (祇園たんと) — DINNER alt (east side) · STOP 3 alt</name>
      <description><![CDATA[<b>STOP 3 ALT · Wed 16:30-21:30 LO 21:30 · CLOSED Thursday</b><br><br><b>WHAT IT IS:</b> Kyoto-style fluffy okonomiyaki + teppan + chuhai. Small counter on Shirakawa Canal near Tatsumi Bridge.<br><br><b>WHY FOR YOU:</b> EAST-SIDE okonomiyaki alt — cross Shijo-Ohashi to Gion if you want this. Closes 21:30 (earlier than Mitsuki). Picking this changes the rest of the night — you're already in Gion, so straight to Stop 4.<br><br>Address: 京都市東山区清本町372<br><br><b>↪ ~12 min from Ritz · cross Shijo-Ohashi from Stop 2</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7745,35.00455,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍺 Gion Tachinomi Yamaneko (山根子) · STOP 4</name>
      <description><![CDATA[<b>STOP 4 · ~22:00 · Daily 11:00-24:00 · cash-on per drink</b><br><br><b>WHAT IT IS:</b> Tachinomi inside 150-year-old machiya. 8 Kyoto craft beers on tap + sake refrigerator self-serve. Maizuru dried fish.<br><br><b>WHY FOR YOU:</b> Cross Shijo-Ohashi from Pontocho to Gion (if dinner was 3A Mitsuki) — Yamaneko is the anchor on the Gion side. Open till 24:00 = generous timing.<br><br>Address: 京都市東山区祇園町北側321-1<br><br><b>↪ ~13 min from Ritz · 5 min from Gion-Shijo station</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.77735,35.00375,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Yamaguchi Daitei Higashi (山口大亭 東店) · STOP 4 alt</name>
      <description><![CDATA[<b>STOP 4 ALT · Mon-Thu + Sat 17:00-22:00 LO 21:30 · CLOSED Sun + holidays · Wed open</b><br><br><b>WHAT IT IS:</b> 50+ year old neighborhood izakaya. 6-seat counter + 2F tatami. Oden, beef-tendon stew, large-bottle beer.<br><br><b>WHY FOR YOU:</b> Same Gion micro-area as 4A (~50m apart). ⚠ Closes 22:00 LO 21:30 — go BEFORE 4A if doing both.<br><br>Address: 京都市東山区祇園町北側286<br><br><b>↪ ~14 min from Ritz, adjacent to 4A</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7762,35.00345,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Gahojin Kappa (我逢人かっぱ) — ¥390 everything · STOP 5</name>
      <description><![CDATA[<b>STOP 5 · late ~23:00+ · Tue-Sat 18:00-03:00 · Sun 17:00-00:30 · CLOSED Mon</b><br><br><b>WHAT IT IS:</b> 6-seat counter + 2F tatami. EVERY item ¥390+tax (yakitori, sashimi, tofu, sides). Highball + sake.<br><br><b>WHY FOR YOU:</b> South Gion final stop. ¥390 = no tab math. Open till 03:00 Tue-Sat = the last-stop pick. After this, walk back north to Ritz along Kamogawa.<br><br>Address: 京都市東山区八坂新地末吉町77<br><br><b>↪ ~15 min south from Stop 4 (5-7 min walk down Hanamikoji)</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.7755,35.0021,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Aburiya Bunzo (あぶり屋 ぶんぞう) — gyutan · STOP 5 alt</name>
      <description><![CDATA[<b>STOP 5 ALT · 18:00-03:00 · irregular closing</b><br><br><b>WHAT IT IS:</b> Charcoal-grilled skewer counter. Gyutan (beef tongue) + beef cartilage specialty. Sasami, lemon sour, sake.<br><br><b>WHY FOR YOU:</b> Same south-Gion area as 5A (~3 min walk). Open till 03:00. Pick if you want grilled meat over the ¥390 stack.<br><br>Address: 京都市東山区富永町123<br><br><b>↪ ~14 min from Ritz, adjacent to 5A</b>]]></description>
      <styleUrl>#major</styleUrl>
      <Point><coordinates>135.776,35.00295,0</coordinates></Point>
    </Placemark>
  </Folder>

  <Folder>
    <name>BONUS — discovery zone</name>
    <Placemark>
      <name>🥞 Okonomiyaki Kiraku Sanjo (お好み焼 きらく) — 3rd okonomiyaki</name>
      <description><![CDATA[<b>Wed 11:30-13:40 + 17:00-22:00 LO · CLOSED Mondays</b><br><br><b>WHAT IT IS:</b> Long-time local-favorite Kyoto okonomiyaki + teppan, hidden-alley feel. Fresh chuhai/lemon sours.<br><br><b>WHY FOR YOU:</b> Off-path third okonomiyaki — north Gion / Sanjo-east, would require crossing Sanjo-Ohashi early. Pick if 3A/3B both don't work, OR for a future lunch slot.<br><br>Address: 京都市東山区三条通白川橋東4丁目中之町208<br><br><b>↪ ~15 min from Ritz east via Sanjo</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.779,35.00833,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍋 Tachinomi Momiji (立ち呑み もみじ) — Kiyamachi-Shijo gateway</name>
      <description><![CDATA[<b>Daily 12:00-22:00 LO 21:30 · cash only · standing</b><br><br><b>WHAT IT IS:</b> Standing counter at Kiyamachi-Shijo entrance. Fresh oden + sashimi + lemon sour + sake.<br><br><b>WHY FOR YOU:</b> On the path between Stop 1 and Stop 2 if you have appetite. Fresh sashimi standing alt.<br><br>Address: 京都市中京区鍋屋町225 萩原ビル 1F<br><br><b>↪ On the walking line between 1B and 2A</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.7692,35.0041,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍶 SAKE壱 — 200+ sake counter</name>
      <description><![CDATA[<b>Evening · verify on arrival</b><br><br><b>WHAT IT IS:</b> Walk-in standing counter, 200+ sake varieties.<br><br><b>WHY FOR YOU:</b> Off-path near Stop 2 cluster. Even deeper sake than 1B Origami if you want a sake-fork mid-walk.<br><br>Address: 京都市中京区材木町<br><br><b>↪ Adjacent to 2A/2B cluster</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.7695,35.0042,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Takase Kaikan (たかせ会館) — Taisho kaikan</name>
      <description><![CDATA[<b>Evening · 'sit if empty, stand if crowded'</b><br><br><b>WHAT IT IS:</b> 1920s kaikan housing 10 micro-shops in one building. Homemade osozai, draft beer, sake.<br><br><b>WHY FOR YOU:</b> Off-path Taisho-era curiosity near Stop 2 cluster. Japanese-only.<br><br>Address: Kiyamachi south<br><br><b>↪ Adjacent to 2A/2B cluster</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.7695,35.0045,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍋 Kiyamachi Golden Sakaba — Showa retro late</name>
      <description><![CDATA[<b>Wed 18:00-03:00 · 1F standing · 2F seated</b><br><br><b>WHAT IT IS:</b> Showa-retro standing bar. Highball + chuhai + oden + kushiage ¥300-900.<br><br><b>WHY FOR YOU:</b> Off-path near Stop 1 area (just east of 1A). Late-night option if you want to swing back through Kiyamachi north on the loop home (~03:00 close).<br><br>Address: 京都市中京区木屋町通六角東側材木町184 都会館ビル 1F<br><br><b>↪ Adjacent to 1A, also handy for the walk back to Ritz</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.76925,35.00854,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Kyogoku Stand (京極スタンド) — 1927 retro</name>
      <description><![CDATA[<b>Wed 12:00-21:00 LO 20:45 · CLOSED Tuesdays</b><br><br><b>WHAT IT IS:</b> 1927-founded retro working-class dining hall. Large bottle beer, fried oysters, hayashi rice.<br><br><b>WHY FOR YOU:</b> Off-path between Stops 1 and 2 — but LO 20:45 means daytime/early-evening only. Skip on the golden path.<br><br>Address: 京都市中京区新京極通四条上ル中之町546<br><br><b>↪ On the path between 1B and 2A if before 20:00</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.76781,35.005,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Kokoronokori (立ち呑み ココロノコリ) — natural wine</name>
      <description><![CDATA[<b>~17:00-24:00 · walk-in</b><br><br><b>WHAT IT IS:</b> Natural wine + small plates standing bar near Pontocho south end. Ahi tuna tartare.<br><br><b>WHY FOR YOU:</b> Off-path near Stop 3 if you want wine over chuhai.<br><br>Address: 京都市中京区下樵木町197<br><br><b>↪ Adjacent to 3A</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.7702,35.004,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Revolution Books — bar in bookshop</name>
      <description><![CDATA[<b>~12:00 to late</b><br><br><b>WHAT IT IS:</b> Walk-in standing bar + cookbook shop hybrid, 2F. Sashimi, karaage, whiskey.<br><br><b>WHY FOR YOU:</b> Off-path weird-pick near Stop 2 cluster. Bar inside a bookshop.<br><br>Address: Kawaramachi area, 2F<br><br><b>↪ Adjacent to 2A/2B</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.76945,35.0042,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍋 Suiba Rokkaku-Tomikoji — different branch</name>
      <description><![CDATA[<b>Wed 17:00-23:30 LO 23:30</b><br><br><b>WHAT IT IS:</b> Standing chuhai bar. Sawa (lemon sour) + Kyoto sake.<br><br><b>WHY FOR YOU:</b> Off-path west of the golden line (near Teramachi-Rokkaku, west of Kiyamachi). Different Suiba branch from 1A/2B.<br><br>Address: 京都市中京区六角通柳馬場東入ル77<br><br><b>↪ Off the Kiyamachi line, ~10 min from Ritz west</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.76651,35.00903,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Yamaguchi Nishi (山口西店) — sister of 4B</name>
      <description><![CDATA[<b>17:30-01:00 · CLOSED Sundays</b><br><br><b>WHAT IT IS:</b> Sister of 4B Yamaguchi Daitei. 8-seat counter + 2F tatami. Beef curry stew, seasoned rice, large beer.<br><br><b>WHY FOR YOU:</b> Off-path between Stops 4 and 5 in Gion. Backup to 4B if Daitei is closed/full. Open till 01:00.<br><br>Address: 京都市東山区花見小路末吉町西入ル374-2<br><br><b>↪ Between 4A and 5A on the south-Gion line</b>]]></description>
      <styleUrl>#bonus</styleUrl>
      <Point><coordinates>135.77565,35.0026,0</coordinates></Point>
    </Placemark>
  </Folder>

  <Folder>
    <name>STATIONS — transit hubs</name>
    <Placemark>
      <name>Kawaramachi (Hankyu line)</name>
      <description><![CDATA[<b>Closest to Stops 1-3 west of river</b><br><br><b>WHAT IT IS:</b> Hankyu Kyoto line.]]></description>
      <styleUrl>#station</styleUrl>
      <Point><coordinates>135.76879,35.00343,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Gion-Shijo (Keihan line)</name>
      <description><![CDATA[<b>Cross-river crossing point</b><br><br><b>WHAT IT IS:</b> Keihan line. Shijo-Ohashi bridge is the natural crossover from Stop 3 to Stops 4-5.]]></description>
      <styleUrl>#station</styleUrl>
      <Point><coordinates>135.77272,35.00343,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>Sanjo (Keihan + Tozai)</name>
      <description><![CDATA[<b>North-end crossover</b><br><br><b>WHAT IT IS:</b> Sanjo-Ohashi bridge — alt Kamogawa crossing for the north end of the walk.]]></description>
      <styleUrl>#station</styleUrl>
      <Point><coordinates>135.77151,35.0091,0</coordinates></Point>
    </Placemark>
  </Folder>

</Document>
</kml>
